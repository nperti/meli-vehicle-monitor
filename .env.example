# Mercado Libre
ML_SITE_ID=MLA
ML_ACCESS_TOKEN=

# Vehiculos a monitorear. Se puede ampliar o cambiar sin tocar el codigo.
VEHICLES_JSON=[{"brand":"Nissan","model":"X-Trail Acenta","query":"nissan xtrail acenta"},{"brand":"Nissan","model":"Xterra","query":"nissan xterra"}]

# Frecuencia en modo local/daemon
UPDATE_INTERVAL_HOURS=24
REPORT_INTERVAL_HOURS=24

# Persistencia y reporte
DB_PATH=data/ml_vehicle_monitor.sqlite3
REPORT_DIR=reports
SEARCH_LIMIT=50

# Reporte por email via SMTP
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
EMAIL_SUBJECT=Reporte diario de publicaciones de vehiculos en Mercado Libre

# Reporte a Google Sheets con service account
SHEETS_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=Reporte diario

